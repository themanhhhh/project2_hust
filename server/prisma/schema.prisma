// Prisma Schema — Ecommerce B2C Multi-Vendor
// Kết nối Supabase qua connection pooler (pgBouncer)
// DATABASE_URL = pooler (port 6543), DIRECT_URL = direct (port 5432 cho migrations)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  admin
  customer
}

enum ProductBadge {
  new
  bestseller
  sale
  none
}

enum OrderStatus {
  pending
  pending_payment
  paid
  awaiting_shipment
  awaiting_collection
  in_transit
  delivered
  completed
  confirmed
  shipping
  cancelled
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum ShipmentStatus {
  pending
  picking
  packing
  ready_for_pickup
  picked_up
  in_transit
  out_for_delivery
  delivered
  failed_delivery
  returned
}

enum ShippingMethod {
  seller_fulfillment
  platform_fulfillment
}

enum CarrierService {
  standard
  express
  same_day
}

enum DiscountType {
  percentage
  fixed_amount
}

enum SellerStatus {
  pending
  active
  suspended
}

enum KybStatus {
  pending
  approved
  rejected
}

// ============================================
// USER (Người mua hàng)
// ============================================

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  name          String    @db.VarChar(255)
  phone         String?   @db.VarChar(20)
  role          UserRole  @default(customer)
  is_active     Boolean   @default(true)
  is_delete     Boolean   @default(false)
  created_at    DateTime  @default(now())

  orders    Order[]
  carts     Cart[]
  addresses Address[]
  reviews   Review[]

  @@map("users")
}

// ============================================
// SELLER (Người bán — hoàn toàn độc lập với User)
// ============================================

model Seller {
  id            String       @id @default(uuid()) @db.Uuid
  email         String       @unique @db.VarChar(255)
  password_hash String       @db.VarChar(255)
  store_name    String       @unique @db.VarChar(255)
  description   String?      @db.Text
  logo_url      String?      @db.VarChar(255)
  banner_url    String?      @db.VarChar(255)
  status        SellerStatus @default(pending)
  is_active     Boolean      @default(true)
  is_delete     Boolean      @default(false)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  products Product[]
  kyb      Kyb?

  @@map("sellers")
}

// ============================================
// KYB (Xác thực doanh nghiệp)
// ============================================

model Kyb {
  id                            String    @id @default(uuid()) @db.Uuid
  seller_id                     String    @unique @db.Uuid
  business_name                 String    @db.VarChar(255)
  business_registration_number  String    @db.VarChar(100)
  document_url                  String?   @db.VarChar(255)
  status                        KybStatus @default(pending)
  admin_notes                   String?   @db.Text
  created_at                    DateTime  @default(now())
  updated_at                    DateTime  @updatedAt

  seller Seller @relation(fields: [seller_id], references: [id])

  @@map("kybs")
}

// ============================================
// CATEGORY
// ============================================

model Category {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @db.VarChar(255)
  slug        String     @unique @db.VarChar(255)
  description String?    @db.Text
  image_url   String?    @db.VarChar(255)
  parent_id   String?    @db.Uuid
  is_active   Boolean    @default(true)

  parent   Category?  @relation("CategoryChildren", fields: [parent_id], references: [id])
  children Category[] @relation("CategoryChildren")
  products Product[]

  @@map("categories")
}

// ============================================
// BRAND
// ============================================

model Brand {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  logo_url    String?   @db.VarChar(255)
  description String?   @db.Text
  is_active   Boolean   @default(true)

  products Product[]

  @@map("brands")
}

// ============================================
// PRODUCT
// ============================================

model Product {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(255)
  slug           String       @unique @db.VarChar(255)
  sku            String       @unique @db.VarChar(100)
  price          Decimal      @db.Decimal(12, 2)
  original_price Decimal?     @db.Decimal(12, 2)
  category_id    String?      @db.Uuid
  brand_id       String?      @db.Uuid
  seller_id      String?      @db.Uuid
  stock_quantity Int          @default(0)
  badge          ProductBadge @default(new)
  rating         Decimal      @default(0) @db.Decimal(2, 1)
  is_active      Boolean      @default(true)
  is_delete      Boolean      @default(false)

  category       Category?          @relation(fields: [category_id], references: [id])
  brand          Brand?             @relation(fields: [brand_id], references: [id])
  seller         Seller?            @relation(fields: [seller_id], references: [id])
  order_items    OrderItem[]
  cart_items     CartItem[]
  reviews        Review[]
  product_images ProductImage[]
  flash_sale_products FlashSaleProduct[]
  collections    Collection[]       @relation("ProductCollections")

  @@map("products")
}

// ============================================
// PRODUCT IMAGE
// ============================================

model ProductImage {
  id         String  @id @default(uuid()) @db.Uuid
  product_id String  @db.Uuid
  image_url  String  @db.VarChar(255)
  is_primary Boolean @default(false)
  sort_order Int     @default(0)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

// ============================================
// ORDER
// ============================================

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  order_number    String        @unique @db.VarChar(50)
  user_id         String        @db.Uuid
  campaign_id     String?       @db.Uuid
  total           Decimal       @db.Decimal(12, 2)
  status          OrderStatus   @default(pending_payment)
  payment_status  PaymentStatus @default(pending)
  created_at      DateTime      @default(now())
  otp_code        String?       @db.VarChar(6)
  otp_expires_at  DateTime?
  is_verified     Boolean       @default(false)
  is_delete       Boolean       @default(false)

  user        User        @relation(fields: [user_id], references: [id])
  campaign    Campaign?   @relation(fields: [campaign_id], references: [id])
  order_items OrderItem[]
  shipments   Shipment[]

  @@map("orders")
}

// ============================================
// ORDER ITEM
// ============================================

model OrderItem {
  id         String  @id @default(uuid()) @db.Uuid
  order_id   String  @db.Uuid
  product_id String  @db.Uuid
  quantity   Int
  price      Decimal @db.Decimal(12, 2)

  order   Order   @relation(fields: [order_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@map("order_items")
}

// ============================================
// CART & CART ITEM
// ============================================

model Cart {
  id         String     @id @default(uuid()) @db.Uuid
  user_id    String     @db.Uuid
  created_at DateTime   @default(now())

  user       User       @relation(fields: [user_id], references: [id])
  cart_items CartItem[]

  @@map("carts")
}

model CartItem {
  id         String  @id @default(uuid()) @db.Uuid
  cart_id    String  @db.Uuid
  product_id String  @db.Uuid
  quantity   Int

  cart    Cart    @relation(fields: [cart_id], references: [id])
  product Product @relation(fields: [product_id], references: [id])

  @@map("cart_items")
}

// ============================================
// ADDRESS
// ============================================

model Address {
  id           String  @id @default(uuid()) @db.Uuid
  user_id      String  @db.Uuid
  full_name    String  @db.VarChar(255)
  phone        String  @db.VarChar(20)
  address_line String  @db.VarChar(255)
  city         String  @db.VarChar(100)
  district     String  @db.VarChar(100)
  ward         String? @db.VarChar(100)
  is_default   Boolean @default(false)

  user User @relation(fields: [user_id], references: [id])

  @@map("addresses")
}

// ============================================
// REVIEW
// ============================================

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  product_id String   @db.Uuid
  user_id    String   @db.Uuid
  rating     Int
  comment    String?  @db.Text
  created_at DateTime @default(now())

  product Product @relation(fields: [product_id], references: [id])
  user    User    @relation(fields: [user_id], references: [id])

  @@map("reviews")
}

// ============================================
// CAMPAIGN (Voucher / Discount)
// ============================================

model Campaign {
  id            String       @id @default(uuid()) @db.Uuid
  name          String       @db.VarChar(255)
  code          String       @unique @db.VarChar(50)
  discount_type DiscountType
  discount_value Decimal     @db.Decimal(12, 2)
  min_order     Decimal?     @db.Decimal(12, 2)
  max_discount  Decimal?     @db.Decimal(12, 2)
  usage_limit   Int?
  used_count    Int          @default(0)
  starts_at     DateTime?
  ends_at       DateTime?
  is_active     Boolean      @default(true)

  orders Order[]

  @@map("campaigns")
}

// ============================================
// FLASH SALE
// ============================================

model FlashSale {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @db.VarChar(255)
  starts_at  DateTime
  ends_at    DateTime
  is_active  Boolean  @default(true)

  flash_sale_products FlashSaleProduct[]

  @@map("flash_sales")
}

model FlashSaleProduct {
  id            String  @id @default(uuid()) @db.Uuid
  flash_sale_id String  @db.Uuid
  product_id    String  @db.Uuid
  sale_price    Decimal @db.Decimal(12, 2)
  quantity      Int
  sold          Int     @default(0)

  flash_sale FlashSale @relation(fields: [flash_sale_id], references: [id])
  product    Product   @relation(fields: [product_id], references: [id])

  @@map("flash_sale_products")
}

// ============================================
// SHIPMENT
// ============================================

model Shipment {
  id              String          @id @default(uuid()) @db.Uuid
  order_id        String          @db.Uuid
  tracking_number String?         @db.VarChar(100)
  carrier         String?         @db.VarChar(100)
  status          ShipmentStatus  @default(pending)
  shipping_method ShippingMethod  @default(seller_fulfillment)
  carrier_service CarrierService? @default(standard)
  shipped_at      DateTime?
  delivered_at    DateTime?
  notes           String?         @db.Text
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  order Order @relation(fields: [order_id], references: [id])

  @@map("shipments")
}

// ============================================
// POST (Blog)
// ============================================

model Post {
  id          String   @id @default(uuid()) @db.Uuid
  title       String   @db.VarChar(500)
  slug        String   @unique @db.VarChar(500)
  content     String   @db.Text
  excerpt     String?  @db.Text
  thumbnail   String?  @db.VarChar(255)
  is_published Boolean @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("posts")
}

// ============================================
// COLLECTION (Bộ sưu tập)
// ============================================

model Collection {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  description String?  @db.Text
  image_url   String?  @db.VarChar(255)
  is_active   Boolean  @default(true)

  products Product[] @relation("ProductCollections")

  @@map("collections")
}
